GITHUB_APP_ID=1234567
GITHUB_PRIVATE_KEY_PATH=path/to/private-key.pem
# Alternatively:
# GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

WEBHOOK_SECRET=supersecret

REDIS_URL=redis://localhost:6379/0
RQ_QUEUE=default
RQ_JOB_TIMEOUT=20m
RQ_RESULT_TTL=3600
RQ_FAILURE_TTL=86400
DELIVERY_TTL_SEC=86400

AGENT_WORKDIR=.agent_workdir
KEEP_WORKDIR=0
COMMENT_PROGRESS=1

GITHUB_USER_AGENT=megafix-bot
GITHUB_APP_NAME=megafix-bot
LOG_LEVEL=INFO

# Optional: run a custom command inside repo before committing
# AGENT_APPLY_CMD="python -m ruff check . --fix"

# Optional: LLM service configuration
# LLM_SERVICE_URL=http://localhost:8088
# LLM_SERVICE_API_KEY=your-token
# LLM_SERVICE_TIMEOUT_SEC=60
# LLM_SERVICE_MODEL=default
# LLM_CHECK_CMD="python -m ruff check ."

# SQLite DB for reviewer state
REVIEW_STATE_DB=review_state.db
