# GitHub App credentials
GITHUB_APP_ID=1234567
# Path inside the runtime environment (container or host)
GITHUB_PRIVATE_KEY_PATH=path/to/private-key.pem
# Alternatively, inline key with \n for newlines:
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub webhook shared secret
WEBHOOK_SECRET=supersecret
# Smee channel URL for local dev (used only by the dev profile)
SMEE_URL=https://smee.io/your-channel

# Redis + RQ settings
REDIS_URL=redis://localhost:6379/0
# RQ queue name
RQ_QUEUE=default
# Job timeout for RQ (e.g., 20m, 1h)
RQ_JOB_TIMEOUT=20m
# How long successful/failed results stay in Redis (seconds)
RQ_RESULT_TTL=3600
RQ_FAILURE_TTL=86400
# Webhook delivery dedup TTL (seconds)
DELIVERY_TTL_SEC=86400

# Local workspace for repo clones
AGENT_WORKDIR=.agent_workdir
# Keep workspace dirs after jobs (0/1)
KEEP_WORKDIR=0
# Post progress comments back to the issue (0/1)
COMMENT_PROGRESS=1

# GitHub API headers / logging
GITHUB_USER_AGENT=megafix-bot
GITHUB_APP_NAME=megafix-bot
LOG_LEVEL=INFO

# Git identity used for automated commits
GIT_AUTHOR_NAME=megafix-bot
GIT_AUTHOR_EMAIL=megafix-bot@users.noreply.github.com
GIT_COMMITTER_NAME=megafix-bot
GIT_COMMITTER_EMAIL=megafix-bot@users.noreply.github.com

# Optional: run a custom command inside repo after agent changes, before committing
# AGENT_APPLY_CMD="python -m ruff check . --fix"

# LLM service configuration (required for the code agent)
LLM_SERVICE_URL=http://localhost:8088
LLM_SERVICE_API_KEY=your-token  # or set OPENAI_API_KEY
LLM_SERVICE_TIMEOUT_SEC=60
LLM_SERVICE_MODEL=default
# Max tokens for each LLM completion (omit to use provider default)
LLM_MAX_TOKENS=1024
# Limits for repo context sent to the LLM
LLM_MAX_RELEVANT_FILES=12
LLM_MAX_FILE_BYTES=50000
LLM_MAX_TREE_ENTRIES=5000
# Guardrails against destructive edits
LLM_MAX_DELETED_LINES=200
LLM_MAX_DELETED_RATIO=0.3

# SQLite DB for reviewer state (path inside the runtime)
REVIEW_STATE_DB=review_state.db

# Review pipeline limits
# REVIEW_MAX_DIFF_CHARS=120000
# REVIEW_MAX_PATCH_CHARS=6000
# REVIEW_MAX_LOG_CHARS=4000
# REVIEW_RERUN_MAX_ATTEMPTS=5
